rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: anyone authenticated can read, users can write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Contatos do usuário (subcoleção): só o dono lê/escreve
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Chats: 1:1 conversations
    match /chats/{chatId} {
      allow read, create, update, delete: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
      match /calls/{callId} {
        allow read: if request.auth != null
          && ((resource.data.from == request.auth.uid) || (resource.data.to == request.auth.uid));
        allow create: if request.auth != null
          && request.resource.data.from == request.auth.uid
          && request.resource.data.to is string
          && request.resource.data.from != request.resource.data.to
          && request.resource.data.status in ['ringing', 'offered', 'answered', 'ended'];
        allow update, delete: if request.auth != null
          && ((resource.data.from == request.auth.uid) || (resource.data.to == request.auth.uid));

        match /offerCandidates/{candidateId} {
          allow read, write: if request.auth != null;
        }
        match /answerCandidates/{candidateId} {
          allow read, write: if request.auth != null;
        }
      }
    }
  }
}
