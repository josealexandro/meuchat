rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function chatParticipantsFromId(chatId) {
      return chatId.split('_');
    }

    function isChatParticipant(chatId) {
      return request.auth != null
        && chatParticipantsFromId(chatId).size() == 2
        && chatParticipantsFromId(chatId).hasAny([request.auth.uid]);
    }

    function isOnlyChangedKeys(allowedKeys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowedKeys);
    }

    // Users: anyone authenticated can read, users can write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Contatos do usuário (subcoleção): só o dono lê/escreve
      match /contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Chats: 1:1 conversations
    match /chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if isChatParticipant(chatId)
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.resource.data.participants.hasAll(chatParticipantsFromId(chatId));
      allow update, delete: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string;
        allow update: if isChatParticipant(chatId)
          && isOnlyChangedKeys(['deliveredAt', 'deliveredTo']);
        allow delete: if isChatParticipant(chatId);
      }
      match /calls/{callId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.from is string
          && request.resource.data.to is string
          && request.resource.data.from != request.resource.data.to
          && chatParticipantsFromId(chatId).hasAll([request.resource.data.from, request.resource.data.to])
          && request.resource.data.status in ['ringing', 'offered', 'answered', 'ended'];
        allow update: if isChatParticipant(chatId)
          && request.resource.data.from == resource.data.from
          && request.resource.data.to == resource.data.to
          && request.resource.data.status in ['ringing', 'offered', 'answered', 'ended']
          && isOnlyChangedKeys(['status', 'callId', 'offer', 'answer', 'endedAt']);
        allow delete: if isChatParticipant(chatId);

        match /offerCandidates/{candidateId} {
          allow read: if isChatParticipant(chatId);
          allow create: if isChatParticipant(chatId)
            && request.resource.data.candidate is string
            && request.resource.data.callId is string;
          allow update, delete: if false;
        }
        match /answerCandidates/{candidateId} {
          allow read: if isChatParticipant(chatId);
          allow create: if isChatParticipant(chatId)
            && request.resource.data.candidate is string
            && request.resource.data.callId is string;
          allow update, delete: if false;
        }
      }
    }
  }
}
